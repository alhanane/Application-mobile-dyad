# Configuration de l'application pour la production
# Copiez ce fichier en .env et modifiez les valeurs selon votre configuration

# URL de l'API backend
VITE_API_URL=https://votre-domaine.com/mobile/api

# URL de base de l'application
VITE_APP_URL=https://votre-domaine.com/mobile

# Mode de production
NODE_ENV=production