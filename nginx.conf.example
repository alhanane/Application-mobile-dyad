# Configuration Nginx pour le projet mobile sur Ubuntu 22
# Placez ce fichier dans /etc/nginx/sites-available/mobile
# Puis créez un lien symbolique: sudo ln -s /etc/nginx/sites-available/mobile /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name votre-domaine.com;  # Remplacez par votre domaine

    # Redirection HTTP vers HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name votre-domaine.com;  # Remplacez par votre domaine

    # Chemin racine de l'application
    root /var/www/mobile;
    index index.html index.php;

    # Certificat SSL (Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/votre-domaine.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/votre-domaine.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # Logs
    access_log /var/log/nginx/mobile_access.log;
    error_log /var/log/nginx/mobile_error.log;

    # Headers de sécurité
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Frontend React (fichiers statiques)
    location / {
        try_files $uri $uri/ /index.html;
        
        # Cache pour les fichiers statiques
        location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # Backend PHP API
    location /api/ {
        alias /var/www/mobile/api/;
        try_files $uri $uri/ @api;

        location ~ \.php$ {
            include fastcgi_params;
            fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;  # Ajustez selon votre version PHP
            fastcgi_index index.php;
            fastcgi_param SCRIPT_FILENAME $request_filename;
            fastcgi_param PATH_INFO $fastcgi_path_info;
        }
    }

    location @api {
        rewrite ^/api/(.*)$ /api/index.php?q=$1 last;
    }

    # Panel Admin PHP
    location /admin/ {
        alias /var/www/mobile/admin/;
        try_files $uri $uri/ @admin;

        location ~ \.php$ {
            include fastcgi_params;
            fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;  # Ajustez selon votre version PHP
            fastcgi_index index.php;
            fastcgi_param SCRIPT_FILENAME $request_filename;
            fastcgi_param PATH_INFO $fastcgi_path_info;
        }
    }

    location @admin {
        rewrite ^/admin/(.*)$ /admin/index.php?q=$1 last;
    }

    # Dossier uploads
    location /uploads/ {
        alias /var/www/mobile/uploads/;
        expires 1y;
        add_header Cache-Control "public";
    }

    # Interdire l'accès aux fichiers sensibles
    location ~ /\. {
        deny all;
    }

    location ~ /(config|lib|db)/ {
        deny all;
    }

    # Interdire l'accès aux fichiers de log
    location ~* \.(log|sql)$ {
        deny all;
    }
}