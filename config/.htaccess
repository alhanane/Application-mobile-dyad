# Protéger le dossier config contre l'accès direct

<FilesMatch "\.(php|json|txt|ini|log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Interdire l'accès à tous les fichiers
<Files "*">
    Order Allow,Deny
    Deny from all
</Files>

